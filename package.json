{
  "name": "pratica-cypress-serverest",
  "version": "1.0.0",
  "private": true,
  "description": "Automacao E2E e API com Cypress usando ServeRest",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "cypress run --spec cypress/e2e/web/**/*.cy.js",
    "test:api": "cypress run --spec cypress/e2e/api/**/*.cy.js"
  },
  "devDependencies": {
    "cypress": "^13.17.0"
  }
}
